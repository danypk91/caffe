---
---

<section class="py-20 md:py-28 bg-gradient-to-br from-ambra to-ambra-hover relative overflow-hidden">
  <!-- Pattern decorativo -->
  <div class="absolute inset-0">
    <div class="absolute -top-20 -right-20 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 w-60 h-60 bg-caffe-scuro/15 rounded-full blur-3xl"></div>
    <!-- Chicchi decorativi stilizzati -->
    <svg class="absolute top-10 left-[15%] w-12 h-12 text-white/10 rotate-12" viewBox="0 0 24 24" fill="currentColor">
      <ellipse cx="12" cy="12" rx="8" ry="11" />
      <path d="M12 1c-2 4-2 8 0 12s2 8 0 12" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5" />
    </svg>
    <svg class="absolute bottom-12 right-[20%] w-16 h-16 text-white/10 -rotate-20" viewBox="0 0 24 24" fill="currentColor">
      <ellipse cx="12" cy="12" rx="8" ry="11" />
      <path d="M12 1c-2 4-2 8 0 12s2 8 0 12" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5" />
    </svg>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">

    <div class="reveal-up">
      <span class="inline-block px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-caffe-scuro bg-white/20 rounded-full mb-6">
        Inizia oggi
      </span>
    </div>

    <h2 class="reveal-up font-heading text-3xl sm:text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
      Porta il caffè di qualità<br>nel tuo spazio
    </h2>

    <p class="reveal-up text-lg sm:text-xl text-white/85 max-w-2xl mx-auto mb-10 leading-relaxed">
      Che si tratti di un ufficio, un'azienda o un locale commerciale,
      installiamo e gestiamo il distributore automatico perfetto per le tue esigenze.
      <strong class="text-white">Nessun costo di installazione</strong>, assistenza garantita.
    </p>

    <div class="reveal-up flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/contatti"
        class="group inline-flex items-center gap-2 px-8 py-4 bg-caffe-scuro text-crema font-semibold rounded-full hover:bg-caffe-scuro/90 transition-all duration-300 hover:shadow-xl hover:shadow-caffe-scuro/25 hover:-translate-y-0.5"
      >
        Richiedi un preventivo gratuito
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
      <a
        href="tel:+393XXXXXXXXX"
        class="inline-flex items-center gap-2 px-8 py-4 bg-white/15 text-white font-semibold rounded-full backdrop-blur-sm border border-white/25 hover:bg-white/25 transition-all duration-300 hover:-translate-y-0.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        Chiamaci ora
      </a>
    </div>

  </div>
</section>