---
---

<section class="relative py-32 md:py-40 overflow-hidden">
  <!-- Background con gradient -->
  <div class="hero-servizi-bg absolute inset-0 bg-gradient-to-br from-caffe-scuro via-caffe-medio to-caffe-scuro"></div>

  <!-- Pattern overlay -->
  <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 25% 45%, #D4882C 1px, transparent 1px), radial-gradient(circle at 75% 25%, #D4882C 1px, transparent 1px), radial-gradient(circle at 55% 75%, #D4882C 1.5px, transparent 1.5px); background-size: 60px 60px, 80px 80px, 100px 100px;"></div>

  <!-- Floating shapes -->
  <div class="absolute top-1/3 left-8 w-48 h-48 bg-ambra/5 rounded-full blur-3xl hero-servizi-float"></div>
  <div class="absolute bottom-1/4 right-8 w-56 h-56 bg-crema/5 rounded-full blur-3xl hero-servizi-float-delay"></div>

  <!-- Contenuto -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="reveal-up mb-4">
      <span class="inline-block px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-ambra border border-ambra/30 rounded-full">
        I nostri servizi
      </span>
    </div>

    <h1 class="reveal-up font-heading text-4xl sm:text-5xl md:text-6xl font-bold text-crema leading-tight">
      Un servizio completo,<br>
      <span class="text-ambra">dalla A alla Z</span>
    </h1>

    <p class="reveal-up mt-6 text-lg sm:text-xl text-crema/75 max-w-2xl mx-auto leading-relaxed">
      Ci occupiamo di ogni aspetto della gestione dei distributori automatici: installazione, rifornimento, manutenzione e assistenza tecnica dedicata.
    </p>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .hero-servizi-bg {
    background-size: 200% 200%;
    animation: heroServiziGradient 12s ease infinite;
  }

  @keyframes heroServiziGradient {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .hero-servizi-float {
    animation: heroServiziFloat 8s ease-in-out infinite;
  }

  .hero-servizi-float-delay {
    animation: heroServiziFloat 10s ease-in-out 2s infinite;
  }

  @keyframes heroServiziFloat {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.05); }
  }

  /* Parallax leggero */
  @supports (animation-timeline: scroll()) {
    .hero-servizi-bg {
      animation: heroServiziGradient 12s ease infinite, heroServiziParallax linear;
      animation-timeline: auto, scroll();
      animation-range: normal, 0% 50%;
    }

    @keyframes heroServiziParallax {
      0% { transform: translateY(0) scale(1); }
      100% { transform: translateY(10%) scale(1.03); }
    }
  }
</style>