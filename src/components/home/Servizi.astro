---
const servizi = [
  {
    titolo: 'Installazione',
    descrizione: 'Installiamo gratuitamente il distributore automatico più adatto ai tuoi spazi, senza costi di acquisto né vincoli.',
    icona: 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76Z',
  },
  {
    titolo: 'Rifornimento',
    descrizione: 'Garantiamo un rifornimento puntuale e costante con prodotti selezionati di alta qualità, per una pausa sempre perfetta.',
    icona: 'M7.21 15 2.66 7.14a2 2 0 0 1 .13-2.2L4.4 2.8A2 2 0 0 1 6 2h12a2 2 0 0 1 1.6.8l1.6 2.14a2 2 0 0 1 .14 2.2L16.79 15M11 2v5M17 2v5M2 15h20M17 15v5a1 1 0 0 1-1 1H8a1 1 0 0 1-1-1v-5',
  },
  {
    titolo: 'Manutenzione',
    descrizione: 'Ci occupiamo della manutenzione ordinaria e della pulizia periodica, per distributori sempre efficienti e igienizzati.',
    icona: 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76Z',
    iconaPaths: [
      { tag: 'path', d: 'M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z' },
      { tag: 'path', d: 'M12 6v6l4 2' },
    ],
  },
  {
    titolo: 'Assistenza',
    descrizione: 'Interveniamo rapidamente in caso di guasti o malfunzionamenti, con assistenza tecnica dedicata e tempi di risposta minimi.',
    icona: 'headset',
  },
];
---

<section id="servizi-preview" class="py-20 md:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Intestazione sezione -->
    <div class="text-center mb-14 md:mb-16">
      <div class="reveal-up">
        <span class="inline-block px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-ambra bg-ambra/10 rounded-full mb-4">
          I nostri servizi
        </span>
      </div>
      <h2 class="reveal-up font-heading text-3xl sm:text-4xl md:text-5xl font-bold text-caffe-scuro leading-tight">
        Tutto quello che serve,<br>in un unico partner
      </h2>
      <p class="reveal-up mt-4 text-testo-chiaro text-base sm:text-lg max-w-2xl mx-auto">
        Dall'installazione all'assistenza, ci occupiamo di ogni aspetto della gestione dei distributori automatici.
      </p>
    </div>

    <!-- Card grid con stagger -->
    <div class="stagger-children grid sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">

      <!-- Installazione -->
      <a href="/servizi" class="servizi-card group relative bg-crema-chiaro rounded-2xl p-6 md:p-8 text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:shadow-caffe-scuro/8">
        <div class="mx-auto mb-5 w-14 h-14 bg-ambra/10 rounded-xl flex items-center justify-center transition-colors duration-300 group-hover:bg-ambra/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ambra">
            <!-- Wrench / Installazione -->
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76Z"/>
          </svg>
        </div>
        <h3 class="font-heading text-lg font-bold text-caffe-scuro mb-2">Installazione</h3>
        <p class="text-testo-chiaro text-sm leading-relaxed mb-4">
          Installiamo gratuitamente il distributore più adatto ai tuoi spazi, senza costi di acquisto né vincoli.
        </p>
        <span class="inline-flex items-center gap-1 text-ambra text-sm font-semibold opacity-0 translate-y-1 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0">
          Scopri di più
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </span>
      </a>

      <!-- Rifornimento -->
      <a href="/servizi" class="servizi-card group relative bg-crema-chiaro rounded-2xl p-6 md:p-8 text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:shadow-caffe-scuro/8">
        <div class="mx-auto mb-5 w-14 h-14 bg-ambra/10 rounded-xl flex items-center justify-center transition-colors duration-300 group-hover:bg-ambra/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ambra">
            <!-- Package / Rifornimento -->
            <path d="m7.5 4.27 9 5.15"/>
            <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/>
            <path d="m3.3 7 8.7 5 8.7-5"/>
            <path d="M12 22V12"/>
          </svg>
        </div>
        <h3 class="font-heading text-lg font-bold text-caffe-scuro mb-2">Rifornimento</h3>
        <p class="text-testo-chiaro text-sm leading-relaxed mb-4">
          Rifornimento puntuale e costante con prodotti selezionati di alta qualità, per una pausa sempre perfetta.
        </p>
        <span class="inline-flex items-center gap-1 text-ambra text-sm font-semibold opacity-0 translate-y-1 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0">
          Scopri di più
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </span>
      </a>

      <!-- Manutenzione -->
      <a href="/servizi" class="servizi-card group relative bg-crema-chiaro rounded-2xl p-6 md:p-8 text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:shadow-caffe-scuro/8">
        <div class="mx-auto mb-5 w-14 h-14 bg-ambra/10 rounded-xl flex items-center justify-center transition-colors duration-300 group-hover:bg-ambra/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ambra">
            <!-- Settings / Manutenzione -->
            <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </div>
        <h3 class="font-heading text-lg font-bold text-caffe-scuro mb-2">Manutenzione</h3>
        <p class="text-testo-chiaro text-sm leading-relaxed mb-4">
          Manutenzione ordinaria e pulizia periodica, per distributori sempre efficienti e igienizzati.
        </p>
        <span class="inline-flex items-center gap-1 text-ambra text-sm font-semibold opacity-0 translate-y-1 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0">
          Scopri di più
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </span>
      </a>

      <!-- Assistenza -->
      <a href="/servizi" class="servizi-card group relative bg-crema-chiaro rounded-2xl p-6 md:p-8 text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:shadow-caffe-scuro/8">
        <div class="mx-auto mb-5 w-14 h-14 bg-ambra/10 rounded-xl flex items-center justify-center transition-colors duration-300 group-hover:bg-ambra/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ambra">
            <!-- Headphones / Assistenza -->
            <path d="M3 11h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm0 0a9 9 0 1 1 18 0m0 0v5a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3Z"/>
            <path d="M21 16v2a4 4 0 0 1-4 4h-5"/>
          </svg>
        </div>
        <h3 class="font-heading text-lg font-bold text-caffe-scuro mb-2">Assistenza</h3>
        <p class="text-testo-chiaro text-sm leading-relaxed mb-4">
          Interveniamo rapidamente in caso di guasti, con assistenza tecnica dedicata e tempi di risposta minimi.
        </p>
        <span class="inline-flex items-center gap-1 text-ambra text-sm font-semibold opacity-0 translate-y-1 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0">
          Scopri di più
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </span>
      </a>

    </div>

    <!-- CTA sotto le card -->
    <div class="reveal-up text-center mt-12">
      <a
        href="/servizi"
        class="group inline-flex items-center gap-2 px-8 py-4 bg-caffe-scuro text-crema font-semibold rounded-lg hover:bg-caffe-medio transition-all duration-300 hover:shadow-lg hover:shadow-caffe-scuro/20 hover:-translate-y-0.5"
      >
        Tutti i nostri servizi
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>