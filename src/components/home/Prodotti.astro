---
const prodotti = [
  {
    nome: 'Caffè e Bevande Calde',
    descrizione: 'Espresso, cappuccino, cioccolata calda e tè: il meglio della pausa calda, con miscele selezionate e macchine di ultima generazione.',
    gradiente: 'from-amber-900 to-amber-700',
    iconPaths: [
      'M17 8h1a4 4 0 1 1 0 8h-1',
      'M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z',
      'M6 2v2',
      'M10 2v2',
      'M14 2v2',
    ],
  },
  {
    nome: 'Bibite Fredde',
    descrizione: 'Acqua, succhi, bevande energetiche e bibite gassate: una selezione rinfrescante sempre a portata di mano.',
    gradiente: 'from-sky-700 to-sky-500',
    iconPaths: [
      'M5.5 20H8',
      'M17 3l-2 8h5.5',
      'M6 12h12',
      'M8 12l-2 8',
      'M16 12l-2 8',
      'M9 4l1 4',
      'M15 4l-1 4',
    ],
  },
  {
    nome: 'Snack e Alimentari',
    descrizione: 'Merendine, barrette, frutta secca e snack salati: una varietà di prodotti per ogni gusto e momento della giornata.',
    gradiente: 'from-emerald-700 to-emerald-500',
    iconPaths: [
      'M15 11h.01',
      'M11 15h.01',
      'M16 16h.01',
      'M2 16l20 6-6-20A20 20 0 0 0 2 16',
      'M5.71 17.11a17.04 17.04 0 0 1 11.4-11.4',
    ],
  },
  {
    nome: 'Distributori Combinati',
    descrizione: 'La soluzione completa in un unico distributore: caffè, bibite e snack insieme, ideale per spazi ridotti con massima versatilità.',
    gradiente: 'from-caffe-scuro to-caffe-medio',
    iconPaths: [
      'M4 7V4a2 2 0 0 1 2-2h8.5L20 7.5V20a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-3',
    ],
    extraPaths: [
      { tag: 'polyline', points: '14 2 14 8 20 8' },
      { tag: 'line', x1: '4', y1: '12', x2: '14', y2: '12' },
      { tag: 'line', x1: '4', y1: '15', x2: '14', y2: '15' },
      { tag: 'line', x1: '4', y1: '18', x2: '10', y2: '18' },
    ],
  },
];
---

<section id="prodotti-preview" class="py-20 md:py-28 bg-crema-chiaro">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Intestazione sezione -->
    <div class="text-center mb-14 md:mb-16">
      <div class="reveal-up">
        <span class="inline-block px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-ambra bg-ambra/10 rounded-full mb-4">
          I nostri prodotti
        </span>
      </div>
      <h2 class="reveal-up font-heading text-3xl sm:text-4xl md:text-5xl font-bold text-caffe-scuro leading-tight">
        Distributori per ogni<br>esigenza
      </h2>
      <p class="reveal-up mt-4 text-testo-chiaro text-base sm:text-lg max-w-2xl mx-auto">
        Offriamo una gamma completa di distributori automatici, dalle bevande calde agli snack, per soddisfare ogni necessità.
      </p>
    </div>

    <!-- Card grid -->
    <div class="stagger-children grid sm:grid-cols-2 gap-6 md:gap-8">
      {prodotti.map((prodotto) => (
        <a href="/prodotti" class="prodotto-card group relative bg-white rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:shadow-caffe-scuro/8">
          <!-- Immagine placeholder con gradiente e icona -->
          <div class={`relative h-48 sm:h-56 bg-gradient-to-br ${prodotto.gradiente} flex items-center justify-center overflow-hidden`}>
            <!-- Pattern decorativo -->
            <div class="absolute inset-0 opacity-10">
              <div class="absolute top-4 left-4 w-20 h-20 border-2 border-white rounded-full"></div>
              <div class="absolute bottom-6 right-6 w-32 h-32 border-2 border-white rounded-full"></div>
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 border border-white rounded-full"></div>
            </div>
            <!-- Icona centrale -->
            <div class="relative z-10 w-20 h-20 bg-white/20 backdrop-blur-sm rounded-2xl flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white">
                {prodotto.iconPaths.map((d) => (
                  <path d={d} />
                ))}
                {prodotto.extraPaths?.map((el) => {
                  if (el.tag === 'polyline') return <polyline points={el.points} />;
                  if (el.tag === 'line') return <line x1={el.x1} y1={el.y1} x2={el.x2} y2={el.y2} />;
                  return null;
                })}
              </svg>
            </div>
          </div>
          <!-- Contenuto testuale -->
          <div class="p-6 md:p-8">
            <h3 class="font-heading text-xl font-bold text-caffe-scuro mb-2">
              {prodotto.nome}
            </h3>
            <p class="text-testo-chiaro text-sm leading-relaxed mb-4">
              {prodotto.descrizione}
            </p>
            <span class="inline-flex items-center gap-1 text-ambra text-sm font-semibold opacity-0 translate-y-1 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0">
              Scopri di più
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA sotto le card -->
    <div class="reveal-up text-center mt-12">
      <a
        href="/prodotti"
        class="group inline-flex items-center gap-2 px-8 py-4 bg-caffe-scuro text-crema font-semibold rounded-lg hover:bg-caffe-medio transition-all duration-300 hover:shadow-lg hover:shadow-caffe-scuro/20 hover:-translate-y-0.5"
      >
        Tutti i nostri distributori
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>