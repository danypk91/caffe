---
---

<section class="py-16 md:py-24 bg-crema-chiaro">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-5 gap-10 md:gap-14">

      <!-- Form -->
      <div class="lg:col-span-3">
        <h2 class="reveal-up font-heading text-2xl sm:text-3xl md:text-4xl font-bold text-caffe-scuro mb-2 leading-tight">
          Inviaci un messaggio
        </h2>
        <p class="reveal-up text-testo-chiaro text-base sm:text-lg mb-8">
          Compila il modulo e ti risponderemo entro 24 ore.
        </p>

        <form
          id="contact-form"
          action="https://formspree.io/f/PLACEHOLDER"
          method="POST"
          class="space-y-5"
        >
          <div class="reveal-up grid sm:grid-cols-2 gap-5">
            <div>
              <label for="nome" class="block text-sm font-semibold text-caffe-scuro mb-1.5">Nome e cognome *</label>
              <input
                type="text"
                id="nome"
                name="nome"
                required
                autocomplete="name"
                class="w-full px-4 py-3 rounded-lg border border-caffe-scuro/15 bg-white text-testo placeholder:text-testo-chiaro/50 focus:outline-none focus:ring-2 focus:ring-ambra/40 focus:border-ambra transition-colors"
                placeholder="Mario Rossi"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-caffe-scuro mb-1.5">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-3 rounded-lg border border-caffe-scuro/15 bg-white text-testo placeholder:text-testo-chiaro/50 focus:outline-none focus:ring-2 focus:ring-ambra/40 focus:border-ambra transition-colors"
                placeholder="mario@email.com"
              />
            </div>
          </div>

          <div class="reveal-up grid sm:grid-cols-2 gap-5">
            <div>
              <label for="telefono" class="block text-sm font-semibold text-caffe-scuro mb-1.5">Telefono</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                autocomplete="tel"
                class="w-full px-4 py-3 rounded-lg border border-caffe-scuro/15 bg-white text-testo placeholder:text-testo-chiaro/50 focus:outline-none focus:ring-2 focus:ring-ambra/40 focus:border-ambra transition-colors"
                placeholder="333 123 4567"
              />
            </div>
            <div>
              <label for="tipo" class="block text-sm font-semibold text-caffe-scuro mb-1.5">Tipo di richiesta *</label>
              <select
                id="tipo"
                name="tipo"
                required
                class="w-full px-4 py-3 rounded-lg border border-caffe-scuro/15 bg-white text-testo focus:outline-none focus:ring-2 focus:ring-ambra/40 focus:border-ambra transition-colors"
              >
                <option value="" disabled selected>Seleziona...</option>
                <option value="sopralluogo">Sopralluogo gratuito</option>
                <option value="preventivo">Richiesta preventivo</option>
                <option value="informazioni">Informazioni generali</option>
                <option value="assistenza">Assistenza tecnica</option>
                <option value="altro">Altro</option>
              </select>
            </div>
          </div>

          <div class="reveal-up">
            <label for="messaggio" class="block text-sm font-semibold text-caffe-scuro mb-1.5">Messaggio *</label>
            <textarea
              id="messaggio"
              name="messaggio"
              required
              rows="5"
              class="w-full px-4 py-3 rounded-lg border border-caffe-scuro/15 bg-white text-testo placeholder:text-testo-chiaro/50 focus:outline-none focus:ring-2 focus:ring-ambra/40 focus:border-ambra transition-colors resize-y"
              placeholder="Descrivi le tue esigenze: tipo di spazio, numero di persone, prodotti desiderati..."
            ></textarea>
          </div>

          <div class="reveal-up">
            <button
              type="submit"
              class="group inline-flex items-center gap-2 px-8 py-4 bg-ambra text-white font-semibold rounded-lg hover:bg-ambra-hover transition-all duration-300 hover:shadow-lg hover:shadow-ambra/20 hover:-translate-y-0.5"
            >
              Invia messaggio
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>

          <!-- Success message -->
          <div id="form-success" class="hidden p-4 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm">
            Grazie per il tuo messaggio! Ti risponderemo il prima possibile.
          </div>

          <!-- Error message -->
          <div id="form-error" class="hidden p-4 rounded-lg bg-red-50 border border-red-200 text-red-800 text-sm">
            Si è verificato un errore. Riprova o contattaci direttamente per telefono.
          </div>
        </form>
      </div>

      <!-- Info contatto -->
      <div class="lg:col-span-2">
        <div class="reveal-right sticky top-28 space-y-6">
          <h3 class="font-heading text-xl sm:text-2xl font-bold text-caffe-scuro mb-6">Contatti diretti</h3>

          <!-- Telefono -->
          <a href="tel:+390000000000" class="flex items-start gap-4 p-5 bg-white rounded-xl border border-caffe-scuro/8 hover:border-ambra/30 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-caffe-scuro/5 transition-all duration-300">
            <div class="flex-shrink-0 w-12 h-12 bg-ambra/15 rounded-xl flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ambra">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-caffe-scuro">Telefono</p>
              <p class="text-testo-chiaro text-sm mt-0.5">000 000 0000</p>
            </div>
          </a>

          <!-- Email -->
          <a href="mailto:info@luanamariani.it" class="flex items-start gap-4 p-5 bg-white rounded-xl border border-caffe-scuro/8 hover:border-ambra/30 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-caffe-scuro/5 transition-all duration-300">
            <div class="flex-shrink-0 w-12 h-12 bg-ambra/15 rounded-xl flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ambra">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-caffe-scuro">Email</p>
              <p class="text-testo-chiaro text-sm mt-0.5">info@luanamariani.it</p>
            </div>
          </a>

          <!-- Indirizzo -->
          <div class="flex items-start gap-4 p-5 bg-white rounded-xl border border-caffe-scuro/8">
            <div class="flex-shrink-0 w-12 h-12 bg-ambra/15 rounded-xl flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ambra">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-caffe-scuro">Sede</p>
              <p class="text-testo-chiaro text-sm mt-0.5">Roma e provincia</p>
            </div>
          </div>

          <!-- Orari -->
          <div class="flex items-start gap-4 p-5 bg-white rounded-xl border border-caffe-scuro/8">
            <div class="flex-shrink-0 w-12 h-12 bg-ambra/15 rounded-xl flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ambra">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-caffe-scuro">Orari</p>
              <p class="text-testo-chiaro text-sm mt-0.5">Lun — Ven: 8:00 — 18:00</p>
              <p class="text-testo-chiaro text-sm">Sab: 9:00 — 13:00</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    if (!form) return;

    const successMsg = document.getElementById('form-success')!;
    const errorMsg = document.getElementById('form-error')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = `
        <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        Invio in corso...
      `;

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' },
        });

        if (response.ok) {
          successMsg.classList.remove('hidden');
          form.reset();
        } else {
          errorMsg.classList.remove('hidden');
        }
      } catch {
        errorMsg.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>